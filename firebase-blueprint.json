{
  "entities": {
    "Message": {
      "title": "Guestbook Message",
      "description": "A message left by a student or guest in the graduation guestbook.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the person leaving the message."
        },
        "class": {
          "type": "string",
          "description": "The class category (e.g., XII DKV 1)."
        },
        "content": {
          "type": "string",
          "description": "The message text."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the message was created."
        }
      },
      "required": ["name", "class", "content", "createdAt"]
    },
    "Album": {
      "title": "Gallery Album",
      "description": "A collection of photos and videos for the gallery.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "cover": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video"] },
              "url": { "type": "string" },
              "thumbnail": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "cover", "items", "createdAt"]
    }
  },
  "firestore": {
    "messages": {
      "schema": "Message",
      "description": "Collection of guestbook messages."
    },
    "albums": {
      "schema": "Album",
      "description": "Collection of gallery albums."
    }
  }
}
